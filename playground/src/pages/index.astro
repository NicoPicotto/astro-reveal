---
import Reveal from "astro-reveal/Reveal.astro";
---
<html lang="es">
  <head><meta charset="utf-8" /><title>Test</title></head>
  <body>
    <Reveal animation="up"><h1>Hola</h1></Reveal>
    <div data-reveal="fade">Raw attribute works too</div>
    <Reveal animation="scale" distance="3rem" index={2} as="section">Stagger</Reveal>
    <Reveal animation="up" easing="bounce">Bounce easing (observer/auto only)</Reveal>
    <Reveal animation="left" speed="fast">Fast speed (observer/auto only)</Reveal>
    <Reveal animation="up" distancePreset="large">Large distance (both engines)</Reveal>
    <div data-reveal="fade" data-easing="sharp" data-speed="slow">Raw attrs: sharp + slow</div>
  </body>
</html>
